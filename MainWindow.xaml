<Window x:Class="AzerothUniverseLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="Azeroth Universe Launcher"
        Width="1040" Height="660"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Border x:Name="RootBorder" CornerRadius="10"
            Background="{StaticResource BrushBgDark}"
            BorderBrush="{StaticResource BrushGoldDark}"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.Clip>
                <!-- Empêche le fond d'écran de déborder des coins arrondis de la fenêtre -->
                <RectangleGeometry Rect="0,0,1040,660" RadiusX="10" RadiusY="10"/>
            </Grid.Clip>

            <!-- ================= FOND D'ÉCRAN ================= -->
            <Grid Grid.RowSpan="3">
                <Image x:Name="BackgroundImage" Stretch="UniformToFill" Opacity="0.6"/>
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#CC0B0E13" Offset="0"/>
                            <GradientStop Color="#990B0E13" Offset="0.25"/>
                            <GradientStop Color="#AA0B0E13" Offset="0.7"/>
                            <GradientStop Color="#EE0B0E13" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Image Source="/Assets/background.png" Stretch="Fill"/>
                </Border>
            </Grid>

            <!-- ================= BARRE DE TITRE ================= -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center" Height="28">
                    <TextBlock x:Name="TitleBarText" Text="AZEROTH UNIVERSE LAUNCHER" FontFamily="Segoe UI Semibold"
                               FontSize="11" Foreground="{StaticResource BrushTextSecondary}" VerticalAlignment="Center" Width="163"/>
                    <TextBlock x:Name="TitleBarVersionText" Text="build 3.3.9" FontSize="11" Margin="8,0,0,0"
                               Foreground="{StaticResource BrushGoldDark}" VerticalAlignment="Center" Width="777"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,4,6,0">
                    <Button Content="&#xE921;" Style="{StaticResource TitleBarButtonStyle}" FontFamily="Segoe MDL2 Assets" Click="Minimize_Click"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource TitleBarButtonStyle}" FontFamily="Segoe MDL2 Assets" Click="Close_Click"/>
                </StackPanel>
                <Image Margin="313,32,601,-43" Source="/Assets/icon-universe.png" Stretch="Fill"/>
            </Grid>

            <!-- ================= CONTENU PRINCIPAL ================= -->
            <Grid Grid.Row="1" Margin="24,4,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- En-tête : logo + statut serveur -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderTitleText" Text="AZEROTH UNIVERSE" Style="{StaticResource TitleTextStyle}"/>
                        <TextBlock x:Name="HeaderTaglineText"
                                   Text="Choisissez votre faction et préparez-vous à une aventure épique !"
                                   Foreground="{StaticResource BrushTextSecondary}" FontSize="12.5" Margin="2,4,0,0"/>
                        <Border Height="2" Width="220" HorizontalAlignment="Left" Margin="2,8,0,0"
                                Background="{StaticResource BrushGoldButton}"/>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Padding="16,10" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot" Width="9" Height="9" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{StaticResource BrushTextSecondary}"/>
                            <StackPanel>
                                <TextBlock x:Name="StatusLabelText" Text="Connexion..." FontSize="12"
                                           Foreground="{StaticResource BrushTextPrimary}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="OnlinePlayersText" Text=" " FontSize="11"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Corps : actualités / dossier client / journal -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Actualités -->
                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="ACTUALITÉS" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,12"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="NewsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource BrushPanelLight}"
                                                    BorderBrush="{StaticResource BrushGoldDark}" BorderThickness="0,0,0,1"
                                                    CornerRadius="3" Padding="14,12" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{StaticResource BrushGoldDark}" CornerRadius="2" Padding="6,2" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding TypeLabel}" FontSize="9" FontWeight="Bold"
                                                                       Foreground="#1A140A"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{Binding Date}" FontSize="10.5"
                                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14.5"
                                                               Foreground="{StaticResource BrushTextPrimary}" Margin="0,8,0,4" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Content}" Style="{StaticResource BodyTextStyle}"
                                                               Foreground="{StaticResource BrushTextSecondary}" FontSize="12.5"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Dossier client + Journal -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="DOSSIER CLIENT" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ClientFolderTextBox" Grid.Column="0" IsReadOnly="True"
                                             Background="#1A2029" Foreground="{StaticResource BrushTextPrimary}"
                                             BorderBrush="{StaticResource BrushGoldDark}" BorderThickness="1"
                                             Padding="8,6" FontSize="11.5" VerticalContentAlignment="Center"
                                             Text="Aucun dossier sélectionné"/>
                                    <Button Grid.Column="1" Content="..." Width="34" Margin="8,0,0,0"
                                            Style="{StaticResource GoldOutlineButtonStyle}" Click="BrowseFolder_Click"/>
                                </Grid>
                                <CheckBox x:Name="DeepVerifyCheckBox" Content="Vérification approfondie (MD5)"
                                          Foreground="{StaticResource BrushTextSecondary}" FontSize="11" Margin="1,10,0,0"
                                          Checked="DeepVerifyCheckBox_Changed" Unchecked="DeepVerifyCheckBox_Changed"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="JOURNAL" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,10"/>
                                <ScrollViewer x:Name="JournalScrollViewer" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="JournalItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="10.5"
                                                           Foreground="{StaticResource BrushTextSecondary}"
                                                           TextWrapping="Wrap" Margin="0,0,0,3"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ================= PIED DE PAGE ================= -->
            <Border Grid.Row="2" Background="{StaticResource BrushPanelLight}"
                    BorderBrush="{StaticResource BrushGoldDark}" BorderThickness="0,1,0,0" Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="DownloadStatusText" Text="Prêt." FontSize="12.5"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <ProgressBar x:Name="DownloadProgressBar" Style="{StaticResource GoldProgressBarStyle}"
                                     Width="380" HorizontalAlignment="Left" Margin="0,7,0,0" Minimum="0" Maximum="100" Value="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="SITE WEB" Style="{StaticResource GoldOutlineButtonStyle}" Margin="0,0,8,0" Click="Website_Click"/>
                        <Button Content="S'INSCRIRE" Style="{StaticResource GoldOutlineButtonStyle}" Margin="0,0,8,0" Click="Register_Click"/>
                        <Button Content="VÉRIFIER" Style="{StaticResource GoldOutlineButtonStyle}" Margin="0,0,8,0" Click="Verify_Click"/>
                        <Button x:Name="ActionButton" Content="JOUER" Style="{StaticResource PrimaryButtonStyle}" Click="ActionButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
